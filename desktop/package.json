{
    "name": "desktop",
    "version": "0.1.0",
    "private": true,
    "main": "dist/main.js",
    "scripts": {
        "dev": "concurrently \"pnpm --filter frontend dev\" \"wait-on http://localhost:5173 && electron .\"",
        "build": "tsc -p tsconfig.json && electron-builder",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "serialport": "^12.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.10",
        "concurrently": "^8.2.2",
        "electron": "^31.3.1",
        "electron-builder": "^24.13.3",
        "typescript": "^5.4.5",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.stembotix.maixide",
        "productName": "MaixIDE",
        "directories": {
            "output": "out"
        },
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        },
        "mac": {
            "target": "dmg"
        }
    }
}